<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace=mapper接口类的全限定名,这样实现对应-->
<mapper namespace="com.furniture.mapper.CategoryMapper">
    <!-- 查询所有分类 -->
    <select id="findAll" resultType="com.furniture.entity.Category">
        SELECT * FROM category
    </select>

    <!-- 根据ID查询分类 -->
    <select id="findById" parameterType="java.lang.Integer" resultType="com.furniture.entity.Category">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <!-- 插入分类 -->
    <insert id="insert" parameterType="com.furniture.entity.Category">
        INSERT INTO category (name, parent_id, description, sort_order, status, created_at, updated_at)
        VALUES (#{name}, #{parentId}, #{description}, #{sortOrder}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 更新分类 -->
    <update id="update" parameterType="com.furniture.entity.Category">
        UPDATE category
        SET name = #{name}, parent_id = #{parentId}, description = #{description}, sort_order = #{sortOrder}, status = #{status}, updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!-- 删除分类 -->
    <delete id="delete" parameterType="java.lang.Integer">
        DELETE FROM category WHERE id = #{id}
    </delete>
</mapper>