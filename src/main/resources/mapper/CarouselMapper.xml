<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<!-- namespace=mapper接口类的全限定名,这样实现对应-->
<mapper namespace="com.furniture.mapper.CarouselMapper">
    <!-- 插入轮播图 -->
    <insert id="insert" parameterType="com.furniture.entity.Carousel">
        INSERT INTO carousel (title, description, image, product_id, sort_order, status, created_at, updated_at)
        VALUES (#{title}, #{description}, #{image}, #{productId}, #{sortOrder}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <!-- 更新轮播图 -->
    <update id="update" parameterType="com.furniture.entity.Carousel">
        UPDATE carousel
        SET title = #{title}, description = #{description}, image = #{image}, product_id = #{productId}, sort_order = #{sortOrder}, status = #{status}, updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <!-- 删除轮播图 -->
    <delete id="delete" parameterType="java.lang.Integer">
        DELETE FROM carousel WHERE id = #{id}
    </delete>

    <!-- 根据ID查询轮播图 -->
    <select id="findById" parameterType="java.lang.Integer" resultType="com.furniture.entity.Carousel">
        SELECT * FROM carousel WHERE id = #{id}
    </select>

    <!-- 轮播图结果映射，包含商品信息 -->
    <resultMap id="CarouselWithProductResultMap" type="com.furniture.entity.Carousel">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="image" column="image"/>
        <result property="productId" column="product_id"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <!-- 商品信息 -->
        <result property="productName" column="p_name"/>
        <result property="productPrice" column="p_price"/>
        <result property="productOriginalPrice" column="p_original_price"/>
        <result property="productSales" column="p_sales"/>
        <result property="productRating" column="p_rating"/>
    </resultMap>

    <!-- 获取所有轮播图，包含商品信息 -->
    <select id="findAll" resultMap="CarouselWithProductResultMap">
        SELECT 
            c.*,
            p.name as p_name,
            p.price as p_price,
            p.original_price as p_original_price,
            p.sales as p_sales,
            p.rating as p_rating
        FROM carousel c
        LEFT JOIN product p ON c.product_id = p.id
        ORDER BY c.sort_order ASC, c.id DESC
    </select>

    <!-- 获取启用的轮播图，包含商品信息 -->
    <select id="findByStatus" parameterType="java.lang.Integer" resultMap="CarouselWithProductResultMap">
        SELECT 
            c.*,
            p.name as p_name,
            p.price as p_price,
            p.original_price as p_original_price,
            p.sales as p_sales,
            p.rating as p_rating
        FROM carousel c
        LEFT JOIN product p ON c.product_id = p.id
        WHERE c.status = #{status}
        ORDER BY c.sort_order ASC, c.id DESC
    </select>
</mapper>